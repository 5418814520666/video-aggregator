# 哔哩哔哩开放平台 https://openhome.bilibili.com
BILIBILI_CLIENT_ID=
BILIBILI_CLIENT_SECRET=
BILIBILI_REDIRECT_URI=http://localhost:3001/api/auth/bilibili/callback

# 抖音开放平台 https://developer.open-douyin.com
DOUYIN_CLIENT_KEY=
DOUYIN_CLIENT_SECRET=
DOUYIN_REDIRECT_URI=http://localhost:3001/api/auth/douyin/callback

# 快手开放平台 https://open.kuaishou.com
KUAISHOU_APP_ID=
KUAISHOU_APP_SECRET=
KUAISHOU_REDIRECT_URI=http://localhost:3001/api/auth/kuaishou/callback

# 央视网：可配置一个合规的 HLS 直播源地址（可选）
CCTV_STREAM_URL=

# 服务端端口
PORT=3001
